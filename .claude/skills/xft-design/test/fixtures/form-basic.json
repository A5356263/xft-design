{
  "pageType": "CreatePage",
  "region": "form-region",
  "mode": "basic",
  "sections": [
    {
      "title": "基础信息",
      "description": "录入员工主体字段并完成提交前校验。",
      "fields": [
        {
          "type": "field.text",
          "label": "姓名",
          "required": true,
          "span": 1,
          "props": { "placeholder": "请输入姓名", "help": "与身份证姓名保持一致" }
        },
        {
          "type": "field.select",
          "label": "部门",
          "required": true,
          "span": 1,
          "props": { "placeholder": "请选择部门", "options": ["技术部", "产品部", "市场部"] }
        },
        {
          "type": "field.date",
          "label": "入职日期",
          "required": false,
          "span": 1,
          "props": { "placeholder": "请选择日期" }
        },
        {
          "type": "field.switch",
          "label": "启用通知",
          "required": false,
          "span": 1,
          "props": { "checked": true, "description": "开启后将通知部门负责人" }
        },
        {
          "type": "field.textarea",
          "label": "备注",
          "required": false,
          "span": 2,
          "props": { "placeholder": "请输入备注信息", "rows": 4, "help": "补充说明信息" }
        },
        {
          "type": "field.multiSelect",
          "label": "权限角色",
          "required": true,
          "span": 2,
          "props": { "options": ["系统管理员", "业务管理员", "普通用户", "只读用户"] }
        }
      ]
    }
  ],
  "actions": [
    { "type": "button.secondary", "label": "取消" },
    { "type": "button.primary", "label": "提交" }
  ]
}
