{
  "project": {
    "project_id": "example-list-management",
    "name": "列表管理示例"
  },
  "shared_context": {},
  "pages": [
    {
      "page_id": "customer-list",
      "page_type": "list-management",
      "page_goal": "让运营人员筛选、浏览并处理客户记录",
      "target_actor": "运营人员",
      "primary_tasks": [
        "按条件筛选客户",
        "浏览客户列表",
        "执行批量或单项操作"
      ],
      "layout_mode": "standard",
      "review_criteria": [
        "筛选条件是否完整但不过载",
        "主要操作是否集中且明确"
      ],
      "sections": [
        {
          "section_id": "primary-content",
          "section_role": "primary_content",
          "priority": "high",
          "placement_preference": "main",
          "blocks": [
            {
              "block_id": "customer-filters",
              "block_pattern": "filter_form",
              "semantic_payload": {
                "content_model_ref": "query_conditions",
                "instance_payload": {
                  "fields": ["customer_name", "status", "owner"]
                }
              },
              "presentation_preference": {
                "layout_style": "inline-compact"
              }
            },
            {
              "block_id": "customer-actions",
              "block_pattern": "action_cluster",
              "semantic_payload": {
                "content_model_ref": "action_set",
                "instance_payload": {
                  "primary_action": "create_customer",
                  "secondary_actions": ["export"]
                }
              },
              "presentation_preference": {}
            },
            {
              "block_id": "customer-table",
              "block_pattern": "record_table",
              "semantic_payload": {
                "content_model_ref": "record_collection",
                "instance_payload": {
                  "fields": ["customer_name", "status", "owner"]
                }
              },
              "presentation_preference": {
                "row_density": "comfortable"
              }
            }
          ]
        }
      ]
    }
  ]
}
